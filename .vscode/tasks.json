{
  // Veja https://go.microsoft.com/fwlink/?LinkId=733558
  // para a documentação sobre o formato tasks.json
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compilar: CHANGEME_TASKLABEL",
      "type": "shell",
      "command": ".vscode/scripts/run_sql.sh",
      "args": [
        // "${relativeFile}",
        // "${file}"
        // Aspas duplas escapadas são necessárias para compatibilidade com Cmder no Windows
        "\"${relativeFile}\"",
        "\"${file}\""
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {},
      "problemMatcher": []
    },
    // EXPORTAR aplicações apex
    {
      "label": "exportar apex: CHANGEME_TASKLABEL",
      "type": "shell",
      "command": ".vscode/scripts/apex_export.sh",
      "args": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {},
      "problemMatcher": []
    },
    {
      "label": "gerar objeto: CHANGEME_TASKLABEL",
      "type": "shell",
      "command": ".vscode/scripts/gen_object.sh",
      "args": [
        "${input:newObjectType}",
        "${input:newObjectName}"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {},
      "problemMatcher": []
    },
  ],
  "inputs": [
    {
      "type": "pickString",
      "id": "newObjectType",
      "description": "Tipo de objeto a incluir",
      // Nota: estas opções devem corresponder ao que está em scripts/project-config.sh
      "options": [
        "package",
        "view",
        "data_array",
        "data_json"
      ]
    },
    {
      "type": "promptString",
      "id": "newObjectName",
      "description": "Nome do objeto"
    }
  ]
}
